<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NeuroGrid Interface</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }

    .glow:hover { box-shadow: 0 0 25px rgba(255,255,255,0.08); }

    .pulse {
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%,100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* LED GRID */
    .grid-led {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .led {
      width: 22px;
      height: 22px;
      border-radius: 6px;
      background: #111;
      transition: all 0.2s ease;
    }

    .led.active.blue { background: #3b82f6; box-shadow: 0 0 12px #3b82f6; }
    .led.active.red { background: #ef4444; box-shadow: 0 0 12px #ef4444; }
    .led.active.green { background: #22c55e; box-shadow: 0 0 12px #22c55e; }
    .led.active.yellow { background: #eab308; box-shadow: 0 0 12px #eab308; }

  </style>
</head>
<body class="bg-neutral-950 text-neutral-200">

  <!-- NAV -->
  <nav class="fixed top-0 w-full backdrop-blur bg-neutral-900/60 border-b border-neutral-800 z-50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-sm tracking-widest text-neutral-400">NEUROGRID</h1>
      <div class="flex gap-6 text-sm text-neutral-500">
        <a href="#modes" class="hover:text-white transition">Modes</a>
        <a href="#features" class="hover:text-white transition">Features</a>
        <a href="#manual" class="hover:text-white transition">Manual</a>
      </div>
      <div class="flex items-center gap-2 text-xs text-green-400">
        <div class="w-2 h-2 bg-green-400 rounded-full pulse"></div>
        Connected
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="pt-32 pb-20 px-6 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <div>
        <h2 class="text-4xl font-light mb-6 tracking-tight">NeuroGrid Control Interface</h2>
        <p class="text-neutral-400 max-w-xl mb-10">
          A precision-built cognitive training system designed to test memory, reaction speed, and pattern recognition.
        </p>

        <div class="grid grid-cols-2 gap-4 text-sm">
          <div class="p-4 border border-neutral-800 rounded-xl glow">
            <p class="text-neutral-500">Status</p>
            <p>Connected</p>
          </div>
          <div class="p-4 border border-neutral-800 rounded-xl glow">
            <p class="text-neutral-500">Firmware</p>
            <p>v1.0.3</p>
          </div>
          <div class="p-4 border border-neutral-800 rounded-xl glow">
            <p class="text-neutral-500">Board</p>
            <p>ESP32</p>
          </div>
          <div class="p-4 border border-neutral-800 rounded-xl glow">
            <p class="text-neutral-500">Network</p>
            <p>NeuroGrid_AP</p>
          </div>
        </div>
      </div>

      <!-- LIVE GRID -->
      <div class="flex justify-center">
        <div id="heroGrid" class="grid-led"></div>
      </div>

    </div>
  </section>

  <!-- MODES -->
  <section id="modes" class="px-6 pb-24 max-w-6xl mx-auto">
    <h3 class="text-2xl font-light mb-10">Modes</h3>

    <div class="grid md:grid-cols-3 gap-6">

      <div class="p-6 border border-neutral-800 rounded-2xl hover:border-blue-500 transition glow">
        <h4 class="text-lg mb-3">Normal Mode</h4>
        <div id="normalPreview" class="grid-led mb-4"></div>
        <p class="text-sm text-neutral-400">Progressive memory challenge with increasing sequence length and speed.</p>
      </div>

      <div class="p-6 border border-neutral-800 rounded-2xl hover:border-red-500 transition glow">
        <h4 class="text-lg mb-3">Reverse Mode</h4>
        <div id="reversePreview" class="grid-led mb-4"></div>
        <p class="text-sm text-neutral-400">Replay sequences in reverse order.</p>
      </div>

      <div class="p-6 border border-neutral-800 rounded-2xl hover:border-yellow-500 transition glow">
        <h4 class="text-lg mb-3">Speed Mode</h4>
        <div id="speedPreview" class="grid-led mb-4"></div>
        <p class="text-sm text-neutral-400">Fast-paced reaction challenge.</p>
      </div>

    </div>
  </section>

  <!-- MANUAL -->
  <section id="manual" class="px-6 pb-32 max-w-6xl mx-auto">
    <h3 class="text-2xl font-light mb-6">User Manual</h3>
    <p class="text-neutral-400 mb-4">Full documentation available below:</p>
    <a href="https://raw.githubusercontent.com/parnikaajoshi/NeuroGrid/main/NeuroGrid Manual basic.pdf" target="_blank" class="text-blue-400 hover:underline">Open User Manual (PDF)</a>
  </section>

  <script>
    function createGrid(containerId) {
      const container = document.getElementById(containerId);
      for (let i = 0; i < 9; i++) {
        const led = document.createElement('div');
        led.className = 'led';
        container.appendChild(led);
      }
    }

    function animateSequence(containerId, speed = 500) {
      const container = document.getElementById(containerId);
      const leds = container.children;
      const colors = ['blue','red','green','yellow'];

      setInterval(() => {
        const index = Math.floor(Math.random() * 9);
        const color = colors[Math.floor(Math.random() * colors.length)];

        leds[index].classList.add('active', color);

        setTimeout(() => {
          leds[index].classList.remove('active', color);
        }, speed * 0.8);

      }, speed);
    }

    // Create grids
    createGrid('heroGrid');
    createGrid('normalPreview');
    createGrid('reversePreview');
    createGrid('speedPreview');

    // Animate
    animateSequence('heroGrid', 400);
    animateSequence('normalPreview', 700);
    animateSequence('reversePreview', 700);
    animateSequence('speedPreview', 150);

  </script>

</body>
</html>
